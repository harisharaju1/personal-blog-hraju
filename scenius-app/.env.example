# Supabase — fill in from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Full URL of the deployed app (no trailing slash).
# e.g. https://sceniusblog.vercel.app  or  http://localhost:3000 for local dev
NEXT_PUBLIC_SITE_URL=

# Your Supabase user UUID — find it in Supabase dashboard → Authentication → Users
# Only posts by this author will be shown on the blog.
BLOG_AUTHOR_USER_ID=
